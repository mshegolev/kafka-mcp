# kafka-mcp environment variables
# Copy to .env and fill in values before running.

# --- Required ---
# Comma-separated list of Kafka broker addresses (host:port)
KAFKA_MCP_BOOTSTRAP_SERVERS=localhost:9092

# --- Security (optional) ---
# One of: PLAINTEXT, SASL_PLAINTEXT, SASL_SSL
KAFKA_MCP_SECURITY_PROTOCOL=PLAINTEXT

# SASL settings (required when SECURITY_PROTOCOL is SASL_*)
# One of: PLAIN, SCRAM-SHA-256, SCRAM-SHA-512, GSSAPI
KAFKA_MCP_SASL_MECHANISM=
KAFKA_MCP_SASL_USERNAME=
KAFKA_MCP_SASL_PASSWORD=

# --- Schema Registry (optional) ---
KAFKA_MCP_SCHEMA_REGISTRY_URL=
KAFKA_MCP_SR_USER=
KAFKA_MCP_SR_PASS=

# --- Scan limits ---
# Maximum number of messages to scan per operation (default: 100000)
KAFKA_MCP_MAX_SCAN=100000

# Poll timeout in seconds for consumer.poll() (default: 1.0)
KAFKA_MCP_POLL_TIMEOUT=1.0
